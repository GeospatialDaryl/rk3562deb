 }
 
 static void rknpu_job_done(struct rknpu_job *job, int ret, int core_index)
@@ -485,6 +485,8 @@ static void rknpu_job_done(struct rknpu_job *job, int ret, int core_index)
 	if (atomic_dec_and_test(&job->interrupt_count)) {
