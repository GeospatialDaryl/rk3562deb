# samwise-tablet-dev.env — Developer tablet image
#
# Purpose: Developer image that approximates the current Debian/Phosh
# experience after the underlying platform passes acceptance.
#
# Usage: ./scripts/build-image.sh --profile samwise-tablet-dev

# Base: extends samwise-hardware-test
SAMWISE_TARGET="samwise"
SAMWISE_PROFILE="samwise-tablet-dev"

# Armbian compile.sh parameters
ARMBIAN_BOARD="${ARMBIAN_BOARD:-}"
ARMBIAN_BRANCH="current"
ARMBIAN_RELEASE="bookworm"

# Full image with desktop
ARMBIAN_BUILD_DESKTOP="yes"
ARMBIAN_BUILD_MINIMAL="no"
ARMBIAN_KERNEL_CONFIGURE="no"

# Tablet session
SAMWISE_TABLET_SESSION="phosh"

# Display and input stacks enabled
SAMWISE_DISPLAY_STACK="enabled"
SAMWISE_INPUT_STACK="enabled"

# Firmware
SAMWISE_FIRMWARE_POLICY="explicit"

# Optional components
SAMWISE_DASHBOARD_DEPS="optional"
SAMWISE_NPU_RUNTIME="opt-in"
SAMWISE_DEVELOPER_TOOLS="enabled"

# Network and access
SAMWISE_SSH_ENABLED="yes"
SAMWISE_NETWORK_ENABLED="yes"

# Safety
SAMWISE_EMMC_WRITE_POLICY="forbidden"
SAMWISE_BOOT_TARGET="removable-microsd"

SAMWISE_ROOTFS_TYPE="ext4"
