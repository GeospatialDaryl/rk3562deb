# samwise-minimal.env — Headless boot and hardware-baseline smoke test
#
# Purpose: Minimal CLI image for initial boot validation.
# No desktop, no display stack, SSH-accessible over network.
#
# Usage: ./scripts/build-image.sh --profile samwise-minimal

# Target identity
SAMWISE_TARGET="samwise"
SAMWISE_PROFILE="samwise-minimal"

# Armbian compile.sh parameters
# NOTE: ARMBIAN_BOARD must be validated against the pinned Armbian revision
# during Phase 1/2. Use a placeholder until discovery confirms the correct
# board identifier or a local board definition is created.
ARMBIAN_BOARD="${ARMBIAN_BOARD:-}"
ARMBIAN_BRANCH="current"
ARMBIAN_RELEASE="bookworm"

# Image type
ARMBIAN_BUILD_DESKTOP="no"
ARMBIAN_BUILD_MINIMAL="yes"
ARMBIAN_KERNEL_CONFIGURE="no"

# Network and access
SAMWISE_SSH_ENABLED="yes"
SAMWISE_NETWORK_ENABLED="yes"

# Safety
SAMWISE_EMMC_WRITE_POLICY="forbidden"
SAMWISE_BOOT_TARGET="removable-microsd"

# Image format
SAMWISE_ROOTFS_TYPE="ext4"
