# samwise-hardware-test.env — Hardware validation image
#
# Purpose: Test DSI display, touch, power, Wi-Fi, sensors, and media
# without committing to a full desktop session (Phosh).
#
# Usage: ./scripts/build-image.sh --profile samwise-hardware-test

# Base: inherit from samwise-minimal
SAMWISE_TARGET="samwise"
SAMWISE_PROFILE="samwise-hardware-test"

# Armbian compile.sh parameters
ARMBIAN_BOARD="${ARMBIAN_BOARD:-}"
ARMBIAN_BRANCH="current"
ARMBIAN_RELEASE="bookworm"

# Image type: not fully minimal, but not a full desktop
ARMBIAN_BUILD_DESKTOP="no"
ARMBIAN_BUILD_MINIMAL="no"
ARMBIAN_KERNEL_CONFIGURE="no"

# Display and input stacks enabled
SAMWISE_DISPLAY_STACK="enabled"
SAMWISE_INPUT_STACK="enabled"

# Firmware: explicit and versioned
SAMWISE_FIRMWARE_POLICY="explicit"

# Test tools
SAMWISE_TEST_TOOLS="enabled"

# Desktop: lightweight diagnostic environment only
SAMWISE_DESKTOP="diagnostic"

# Network and access
SAMWISE_SSH_ENABLED="yes"
SAMWISE_NETWORK_ENABLED="yes"

# Safety
SAMWISE_EMMC_WRITE_POLICY="forbidden"
SAMWISE_BOOT_TARGET="removable-microsd"

SAMWISE_ROOTFS_TYPE="ext4"
