#!/bin/sh
# Force RK817 DEV_OFF during systemd poweroff to avoid reboot loops.
# systemd passes one argument: halt|poweroff|reboot|kexec

ACTION="${1:-}"
[ "${ACTION}" = "poweroff" ] || exit 0

# Only attempt on systems that expose i2c buses.
ls /dev/i2c-* >/dev/null 2>&1 || exit 0

# Preferred path: direct i2c ioctl/write, preserving existing SYS_CFG3 bits.
if command -v python3 >/dev/null 2>&1; then
python3 - <<'PY' >/dev/null 2>&1 || true
import glob
import os
import fcntl

I2C_SLAVE_FORCE = 0x0706
RK817_ADDR = 0x20
SYS_CFG3 = 0xF4


def try_bus(path: str) -> bool:
    fd = os.open(path, os.O_RDWR | os.O_CLOEXEC)
    try:
        fcntl.ioctl(fd, I2C_SLAVE_FORCE, RK817_ADDR)
        os.write(fd, bytes([SYS_CFG3]))
        data = os.read(fd, 1)
        if len(data) != 1:
            return False
        new_val = data[0] | 0x01  # DEV_OFF
        os.write(fd, bytes([SYS_CFG3, new_val]))
        return True
    finally:
        os.close(fd)


seen = set()
for path in ["/dev/i2c-0"] + sorted(glob.glob("/dev/i2c-*")):
    if path in seen:
        continue
    seen.add(path)
    try:
        if try_bus(path):
            raise SystemExit(0)
    except Exception:
        pass

raise SystemExit(1)
PY
fi

# Fallback path when python is unavailable.
if command -v i2cget >/dev/null 2>&1 && command -v i2cset >/dev/null 2>&1; then
    for bus in 0 1 2 3 4 5 6 7; do
        [ -e "/dev/i2c-${bus}" ] || continue
        val="$(i2cget -f -y "${bus}" 0x20 0xF4 2>/dev/null || true)"
        [ -n "${val}" ] || continue
        new_val="$(printf "0x%02x" $((val | 0x01)))"
        i2cset -f -y "${bus}" 0x20 0xF4 "${new_val}" >/dev/null 2>&1 && break
    done
fi

# Give PMIC a brief window to cut power before kernel fallback paths run.
sleep 1
exit 0
